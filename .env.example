# Copy this to .env.local and fill in your values
# The app works WITHOUT these — it uses in-memory storage and template AI summaries as fallbacks

# Anthropic API (for AI-generated audit summaries)
# Get free credits at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase (for persisting audits and leads)
# Create a free project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key

# Resend (for transactional email)
# Free tier at: https://resend.com (100 emails/day free)
RESEND_API_KEY=re_your-key-here
